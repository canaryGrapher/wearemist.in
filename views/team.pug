#header
  h1 Meet the team.
  a#applyButton(onclick='showDialog()')
    | How to apply
#teamLinksNavbar
  #cc.teamLinkBox
    a#ccLink(onclick='showCC()') Core Committee
  #mc.teamLinkBox
    a#mcLink(onclick='showMC()') Management Committee
  #wc.teamLinkBox
    a#wcLink(onclick='showWC()') Working Committee
#corec
  each val1, index1 in CC
    .ccprofile
        - var firstName = CC[index1].name.split(" ");
        - var divID = firstName[0]+firstName[1]
        .ccPhoto(id=divID)
        style.
          ##{divID} {
            background-image: url("#{CC[index1].photo}");
          }
        .cmemberInfo
            h1.cmemberName #{CC[index1].name}
            p.cmemberPosition #{CC[index1].position}
            p.interestsMember #{CC[index1].interests}
#manc
  each val2, index2 in MC
    .mcprofile
        - var firstName = MC[index2].name.split(" ");
        - var divID = firstName[0]+firstName[1]
        .mcPhoto(id=divID)
        style.
          ##{divID} {
            background-image: url("#{MC[index2].photo}");
          }
        .mmemberInfo
            h1.mcmemberName #{MC[index2].name}
            p.interestsMember #{MC[index2].interests}
#workc
  each val3, index3 in WC
    .wcprofile
        .wmemberInfo
            h1.wcmemberName #{WC[index3].name}
